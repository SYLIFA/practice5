search_result = re.search(r"\uc0\u1062 \u1077 \u1085 \u1072 :\\s*(\\d+)", sample_text)\
print("1. search() -> \uc0\u1053 \u1072 \u1096 \u1083 \u1080  \u1094 \u1077 \u1085 \u1091 :", search_result.group(1))\
\
# 2. re.findall() - \uc0\u1053 \u1072 \u1093 \u1086 \u1076 \u1080 \u1090  \u1042 \u1057 \u1045  \u1089 \u1086 \u1074 \u1087 \u1072 \u1076 \u1077 \u1085 \u1080 \u1103  \u1074  \u1074 \u1080 \u1076 \u1077  \u1089 \u1087 \u1080 \u1089 \u1082 \u1072 \
# \\d+ \uc0\u1086 \u1079 \u1085 \u1072 \u1095 \u1072 \u1077 \u1090  "\u1083 \u1102 \u1073 \u1086 \u1077  \u1095 \u1080 \u1089 \u1083 \u1086  \u1080 \u1079  \u1086 \u1076 \u1085 \u1086 \u1081  \u1080 \u1083 \u1080  \u1073 \u1086 \u1083 \u1077 \u1077  \u1094 \u1080 \u1092 \u1088 "\
findall_result = re.findall(r"\\d+", sample_text)\
print("2. findall() -> \uc0\u1042 \u1089 \u1077  \u1095 \u1080 \u1089 \u1083 \u1072  \u1074  \u1090 \u1077 \u1082 \u1089 \u1090 \u1077 :", findall_result)\
\
# 3. re.split() - \uc0\u1056 \u1072 \u1079 \u1088 \u1077 \u1079 \u1072 \u1077 \u1090  \u1089 \u1090 \u1088 \u1086 \u1082 \u1091 \
# \\.\\s* \uc0\u1086 \u1079 \u1085 \u1072 \u1095 \u1072 \u1077 \u1090  "\u1090 \u1086 \u1095 \u1082 \u1072  \u1080  \u1074 \u1086 \u1079 \u1084 \u1086 \u1078 \u1085 \u1099 \u1081  \u1087 \u1088 \u1086 \u1073 \u1077 \u1083  \u1087 \u1086 \u1089 \u1083 \u1077  \u1085 \u1077 \u1077 "\
split_result = re.split(r"\\.\\s*", sample_text)\
print("3. split() -> \uc0\u1056 \u1072 \u1079 \u1088 \u1077 \u1079 \u1072 \u1083 \u1080  \u1085 \u1072  \u1087 \u1088 \u1077 \u1076 \u1083 \u1086 \u1078 \u1077 \u1085 \u1080 \u1103 :\\n", split_result)\
\
