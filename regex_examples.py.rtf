print("=== \uc0\u1055 \u1056 \u1048 \u1052 \u1045 \u1056 \u1067  \u1060 \u1059 \u1053 \u1050 \u1062 \u1048 \u1049  REGEX ===\\n")\
sample_text = "\uc0\u1052 \u1086 \u1081  \u1085 \u1086 \u1084 \u1077 \u1088 : 8-777-123-45-67. \u1062 \u1077 \u1085 \u1072 : 5000 \u1090 \u1077 \u1085 \u1075 \u1077 . \u1057 \u1082 \u1080 \u1076 \u1082 \u1072 : 15%"\
\
# 1. re.search() - \uc0\u1053 \u1072 \u1093 \u1086 \u1076 \u1080 \u1090  \u1058 \u1054 \u1051 \u1068 \u1050 \u1054  \u1087 \u1077 \u1088 \u1074 \u1086 \u1077  \u1089 \u1086 \u1074 \u1087 \u1072 \u1076 \u1077 \u1085 \u1080 \u1077 \
