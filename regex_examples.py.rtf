# \uc0\u1047 \u1072 \u1084 \u1077 \u1085 \u1103 \u1077 \u1084  \u1074 \u1089 \u1077  \u1094 \u1080 \u1092 \u1088 \u1099  (\\d) \u1085 \u1072  'X', \u1095 \u1090 \u1086 \u1073 \u1099  \u1089 \u1082 \u1088 \u1099 \u1090 \u1100  \u1076 \u1072 \u1085 \u1085 \u1099 \u1077 \
sub_result = re.sub(r"\\d", "X", sample_text)\
print("4. sub() -> \uc0\u1057 \u1082 \u1088 \u1099 \u1083 \u1080  \u1074 \u1089 \u1077  \u1094 \u1080 \u1092 \u1088 \u1099 :\\n", sub_result)}